# Copy to .env.prod on the server, fill in, chmod 600. NEVER commit .env.prod.

# Public hostname (must have a DNS A record → server IP before deploy)
APP_HOST=library.example.com

# Native host Postgres (host.docker.internal from inside the container)
DATABASE_URL=postgresql://kb:CHANGE_ME@host.docker.internal:5432/knowledge_base

# Session cookie signing — generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_64_HEX_CHARS
COOKIE_SECURE=true

# MiniMax (the only external API). Confirm base URL + model for your account.
MINIMAX_API_KEY=CHANGE_ME
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01

# Spend guardrails
RATE_LIMIT_PER_DAY=200
TOKEN_BUDGET_PER_DAY=300000
MAX_ANSWER_TOKENS=500
TOP_K=5

# Login lockout
MAX_FAILED_ATTEMPTS=5
LOCKOUT_MINUTES=15
